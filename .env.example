# ── Entorno ───────────────────────────────────────────────────
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────
# Obtenidos desde: Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin trailing slash)
# Producción: el dominio de cPanel
# Desarrollo: localhost
ALLOWED_ORIGINS=http://localhost:5173,https://tu-dominio-cpanel.com

# ── WhatsApp ──────────────────────────────────────────────────
# Número con código de país, sin espacios ni guiones
WHATSAPP_PHONE=573001234567

# ── Carrito ───────────────────────────────────────────────────
# Horas de inactividad antes de expirar el carrito
CART_EXPIRY_HOURS=72

# ── Rate Limiting (Upstash Redis) ─────────────────────────────
# Opcional en desarrollo — requerido en producción
# Obtenidos desde: console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
